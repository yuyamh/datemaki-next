{
    "name": "nextjs-boilerplate",
    "version": "0.1.0",
    "private": true,
    "type": "module",
    "scripts": {
        "dev": "next dev --turbopack",
        "build": "next build",
        "start": "next start",
        "lint": "pnpm eslint . --ext .js,.jsx,.ts,.tsx,.mjs && prisma validate",
        "lint:fix": "pnpm eslint . --ext .js,.jsx,.ts,.tsx,.mjs --fix",
        "typecheck": "tsc --skipLibCheck true --noEmit",
        "typecheck:full": "tsc --skipLibCheck false --noEmit",
        "format": "prettier --check \"**/*.{ts,tsx,js,jsx,cjs,mjs,md,json,lintstagedrc,yml,yaml}\" --cache",
        "format:fix": "prettier --write \"**/*.{ts,tsx,js,jsx,cjs,mjs,md,json,lintstagedrc,yml,yaml}\" --cache && prisma format",
        "clean": "git clean -xdf node_modules dist .next",
        "prepare": "husky",
        "db:seed": "prisma db seed",
        "postinstall": "prisma generate"
    },
    "prisma": {
        "seed": "pnpm tsx src/server/db/prisma/seed.ts"
    },
    "dependencies": {
        "@hookform/resolvers": "^5.2.2",
        "@prisma/client": "6.5.0",
        "@radix-ui/react-alert-dialog": "^1.1.15",
        "@radix-ui/react-avatar": "^1.1.10",
        "@radix-ui/react-checkbox": "^1.3.3",
        "@radix-ui/react-dialog": "^1.1.15",
        "@radix-ui/react-dropdown-menu": "^2.1.16",
        "@radix-ui/react-label": "^2.1.7",
        "@radix-ui/react-navigation-menu": "^1.2.14",
        "@radix-ui/react-popover": "^1.1.15",
        "@radix-ui/react-radio-group": "^1.3.8",
        "@radix-ui/react-select": "^2.2.6",
        "@radix-ui/react-separator": "^1.1.7",
        "@radix-ui/react-slider": "^1.3.6",
        "@radix-ui/react-slot": "^1.2.3",
        "@radix-ui/react-switch": "^1.2.6",
        "@radix-ui/react-tabs": "^1.1.13",
        "@t3-oss/env-nextjs": "^0.13.8",
        "bcryptjs": "^3.0.3",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "date-fns": "^4.1.0",
        "lucide-react": "^0.545.0",
        "next": "16.0.10",
        "next-auth": "5.0.0-beta.30",
        "next-themes": "^0.4.6",
        "react": "^19.0.0",
        "react-day-picker": "^9.11.1",
        "react-dom": "^19.0.0",
        "react-hook-form": "^7.65.0",
        "sonner": "^2.0.7",
        "tailwind-merge": "^3.3.1",
        "tailwindcss-animate": "^1.0.7",
        "zod": "^4.1.11"
    },
    "devDependencies": {
        "@eslint/eslintrc": "^3",
        "@ianvs/prettier-plugin-sort-imports": "^4.7.0",
        "@tailwindcss/postcss": "^4",
        "@types/eslint-plugin-security": "^3.0.0",
        "@types/node": "^20",
        "@types/react": "^19",
        "@types/react-dom": "^19",
        "baseline-browser-mapping": "^2.9.7",
        "eslint": "^9.37.0",
        "eslint-config-next": "15.3.1",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-perfectionist": "^4.15.0",
        "eslint-plugin-security": "^3.0.1",
        "eslint-plugin-unicorn": "^61.0.2",
        "eslint-plugin-unused-imports": "^4.2.0",
        "husky": "^9.1.7",
        "lint-staged": "^16.2.3",
        "postcss-load-config": "^6.0.1",
        "prettier": "^3.6.2",
        "prettier-plugin-tailwindcss": "^0.6.14",
        "prisma": "6.5.0",
        "tailwindcss": "^4",
        "tsx": "^4.20.6",
        "tw-animate-css": "^1.4.0",
        "typescript": "^5",
        "typescript-eslint": "^8.45.0"
    },
    "engines": {
        "node": "22.x"
    }
}

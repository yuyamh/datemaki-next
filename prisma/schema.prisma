// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"] // Vercelへのデプロイ用
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

generator zod {
  provider          = "zod-prisma-types"
  useMultipleFiles  = true
  writeBarrelFiles  = false
  useTypeAssertions = true
  output            = "../src/server/db/prisma/generated/zod"
}

// 教案
model Post {
  id                String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title             String
  description       String?
  level             CEFR?
  textbookId        String?    @db.Uuid
  textbook          Textbook?  @relation(fields: [textbookId], references: [id])
  userId            String     @db.Uuid
  user              User       @relation(fields: [userId], references: [id])
  fileName1         String?
  fileName2         String?
  fileName3         String?
  fileOriginalName1 String?
  fileOriginalName2 String?
  fileOriginalName3 String?
  fileSize1         Int?
  fileSize2         Int?
  fileSize3         Int?
  downloadCount     Int        @default(0)
  bookmarks         Bookmark[]
  comments          Comment[]
  createdAt         DateTime   @default(now())
  updatedAt         DateTime   @updatedAt
}

model Bookmark {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  postId    String   @db.Uuid
  createdAt DateTime @default(now())
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, postId])
}

model Comment {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  content   String
  userId    String   @db.Uuid
  postId    String   @db.Uuid
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Textbook {
  id    String @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name  String @unique
  Posts Post[]
}

model User {
  id                  String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                String
  email               String               @unique
  hashedPassword      String               @map("password")
  bio                 String?
  role                Role                 @default(user)
  avatar              String?
  bookmarks           Bookmark[]
  comments            Comment[]
  Posts               Post[]
  passwordResetTokens PasswordResetToken[]
  createdAt           DateTime             @default(now())
  updatedAt           DateTime             @updatedAt
}

model PasswordResetToken {
  id        String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId    String   @db.Uuid
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

// レベル（CEFRに準拠）
enum CEFR {
  A1
  A2
  B1
  B2
  C1
  C2
}

// ロール
enum Role {
  admin
  user
  guest
}
